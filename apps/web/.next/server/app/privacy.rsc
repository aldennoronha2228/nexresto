7:["$","div",null,{"className":"space-y-8 text-sm leading-relaxed text-[#c5c5d6]","children":[["$","section",null,{"children":[["$","h2",null,{"className":"text-lg font-semibold text-white","children":"1. Information We Collect"}],["$","ol",null,{"className":"mt-3 list-decimal space-y-2 pl-5","children":[["$","li",null,{"children":"Account information: name, email, phone, restaurant name, role, and authentication details."}],["$","li",null,{"children":"Business configuration data: menus, table layouts, branding assets, pricing, and outlet settings."}],["$","li",null,{"children":"Transactional data: orders, order status history, and operational activity needed to deliver service."}],["$","li",null,{"children":"Technical data: device type, browser metadata, IP address, and security logs for fraud prevention."}],["$","li",null,{"children":"Support and communication data: tickets, feedback, and messages sent through support channels."}]]}]]}],["$","section",null,{"children":[["$","h2",null,{"className":"text-lg font-semibold text-white","children":"2. How We Use Information"}],["$","ol",null,{"className":"mt-3 list-decimal space-y-2 pl-5","children":[["$","li",null,{"children":"To provide core product functionality and maintain your restaurant workspace."}],["$","li",null,{"children":"To process requests such as onboarding demos, account setup, and support follow-ups."}],["$","li",null,{"children":"To improve reliability, monitor performance, and detect abuse or unauthorized access."}],["$","li",null,{"children":"To communicate service updates, product notices, and important security alerts."}],["$","li",null,{"children":"To meet compliance, auditing, and legal obligations."}]]}]]}],["$","section",null,{"children":[["$","h2",null,{"className":"text-lg font-semibold text-white","children":"3. Legal Bases and Permissions"}],["$","ol",null,{"className":"mt-3 list-decimal space-y-2 pl-5","children":[["$","li",null,{"children":"Contract necessity: data required to deliver su