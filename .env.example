NEXT_PUBLIC_MENU_BASE_URL=https://nexresto.in
NEXT_PUBLIC_MENU_CUSTOMER_PATH=/customer
NEXT_PUBLIC_RESTAURANT_ID=

# Admin auth (server-only)
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
ADMIN_ACCESS_KEY=
AI_CONTROL_ENABLED=
AI_CONTROL_KEY=
CRON_SECRET=

# AI provider keys (server-only)
