{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": false,
    "paths": {
      "@/*": ["./*", "./apps/web/*"]
    }
  },
  "include": [
    "__tests__/**/*.ts",
    "lib/**/*.ts",
    "features/**/*.ts",
    "features/**/*.tsx",
    "services/**/*.ts",
    "types/**/*.ts",
    "jest.config.ts",
    "scripts/**/*.ts",
    "scripts/**/*.mts",
    "apps/web/**/*.ts",
    "apps/web/**/*.tsx"
  ],
  "exclude": ["node_modules", "apps/web/.next/**", "functions/**/*", "vite.config.ts", "vite.config.mts"]
}